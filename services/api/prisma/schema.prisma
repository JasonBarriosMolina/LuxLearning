generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Course {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String
  imageUrl       String?
  isActive       Boolean   @default(false)
  isPilot        Boolean   @default(false)
  tags           String[]  @default([])
  startDate      DateTime?
  closeDate      DateTime?
  isDraft        Boolean   @default(false)
  isArchived     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  createdByName  String?
  evaluatorName  String?
  evaluatorId    String?

  // Wizard fields
  courseType         String?   // TEORICO | TEORICO_PRACTICO | PROYECTOS | CURSO_CORTO | PROGRAMA_ESPECIAL
  academicPeriod     String?
  classDays          String[]  @default([])
  classSchedule      String?
  modality           String?   // PRESENCIAL | SINCRONICA | ASINCRONICA | HIBRIDA
  totalWeeks         Int?
  planLanguage       String?   @default("ES")  // ES | EN
  cardColor          String?
  cardBorderColor    String?
  cardLabels         String[]  @default([])
  calendarExceptions Json?     // [{date, type:'day'|'week', label}]
  evaluationConfig   Json?     // [{type, name, weight, count, dueDate?}]
  planDocumentS3Key  String?   // Word generado

  modules            Module[]
  evaluationEvents   EvaluationEvent[]
  sessions           CourseSession[]
}

model CourseSession {
  id          String   @id @default(cuid())
  courseId    String
  sessionDate DateTime
  weekIndex   Int?
  order       Int
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model AcademicPeriod {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model EvaluationEvent {
  id             String   @id @default(cuid())
  courseId       String
  moduleId       String?  // null = course-level; set to link to a specific module
  type           String   // QUIZ | EVIDENCE | INTERVIEW
  name           String
  dueDate        DateTime?
  weight         Float    // porcentaje (ej. 20.0)
  instructions   String?
  vapiPrompt     String?  // System prompt for Vapi AI interviewer
  vapiObjectives String?  // JSON array of 3 question objectives
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([moduleId])
}

model Module {
  id           String     @id @default(cuid())
  courseId     String
  order        Int
  title        String
  description  String
  duration     String
  passingScore Int
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  questions    Question[]

  @@unique([courseId, order])
}

model Lesson {
  id        String   @id @default(cuid())
  moduleId  String
  order     Int
  title     String
  duration  String
  type      String   @default("video")
  youtubeId String   @default("")
  content   String?
  imageUrl  String?
  audioUrl     String?
  points       String[]
  tip          String
  prevSnapshot String?   // JSON snapshot of fields before last manual edit — for "restore previous version"
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, order])
}

model Question {
  id           String   @id @default(cuid())
  moduleId     String
  order        Int
  text         String
  options      String[]
  correctIndex Int
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, order])
}

model StudentGroup {
  id                    String                  @id @default(cuid())
  name                  String
  description           String?
  color                 String                  @default("#17527E")
  createdByEvaluatorId  String?                 // null = created by admin
  createdAt             DateTime                @default(now())
  members               StudentGroupMember[]
  evaluators            StudentGroupEvaluator[]
}

model StudentGroupMember {
  groupId           String
  userId            String    // Cognito username
  addedAt           DateTime  @default(now())
  enrolledCourseIds String[]  @default([])
  group             StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model StudentGroupEvaluator {
  groupId     String
  evaluatorId String    // Cognito sub (UUID)
  assignedAt  DateTime  @default(now())
  group       StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, evaluatorId])
}
